# ===== Aether backend environment variables =====
# Copy to .env and fill in real values. `.env` is gitignored.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://aether:aether_dev_changeme@localhost:5432/aether

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- LLM (DeepSeek via OpenAI-compatible API) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro
LLM_RATE_LIMIT_PER_MIN=20
LLM_TIMEOUT_SECONDS=30

# --- Jin10 flash news (MCP; 金十快讯) ---
# Access is MCP-only; the key authorizes the streamable-HTTP endpoint below.
JIN10_MCP_URL=https://mcp.jin10.com/mcp
JIN10_API_KEY=sk-...
JIN10_MAX_PAGES_PER_TICK=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Server ---
HOST=0.0.0.0
PORT=8000
